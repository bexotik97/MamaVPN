{
  "name": "@mamavpn/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node -e \"const {spawnSync}=require('node:child_process'); const {dirname,join}=require('node:path'); const prismaPkg=require.resolve('prisma/package.json'); const prismaCli=join(dirname(prismaPkg),'build','index.js'); const result=spawnSync(process.execPath,[prismaCli,'generate','--schema','prisma/schema.prisma'],{stdio:'inherit',env:{...process.env,PRISMA_GENERATE_SKIP_AUTOINSTALL:'1'}}); process.exit(result.status ?? 1);\"",
    "dev": "tsx watch src/main.ts",
    "build": "nest build",
    "start": "node dist/apps/api/src/main.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "prisma": "prisma --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@mamavpn/config": "workspace:*",
    "@mamavpn/shared": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^4.1.1",
    "@prisma/client": "^6.4.1",
    "axios": "^1.8.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "prisma": "^6.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5.7.2"
  }
}
